# =============================================================================
#  Synergit screenshot tool — environment configuration
#
#  Copy this file to `.env` (same folder as package.json):
#      cp .env.example .env
#  Then edit the values for your local Synergit stack and demo fixtures.
#
#  Values set in your shell (via $env:NAME = "...") TAKE PRECEDENCE over .env.
# =============================================================================

# ─── Synergit stack URLs ────────────────────────────────────────────────────
# Frontend SPA (Vite dev server)
SYNERGIT_BASE_URL=http://localhost:5173
# Backend gateway (or monolith) for API login
SYNERGIT_API_URL=http://localhost:8080

# ─── Login credentials ──────────────────────────────────────────────────────
# Used by capture.mjs to POST /api/v1/auth/login and inject the JWT.
SYNERGIT_LOGIN_USER=CaliMinux
SYNERGIT_LOGIN_PASS=changeme

# ─── Fixture data for shots that need a specific entity ─────────────────────
# The user must already have these in the running dev DB before capturing.
SYNERGIT_REPO=synergit-demo
SYNERGIT_PR=1
# PR with merge conflicts (used ONLY by the `synergit-resolve` shot so you can
# screenshot the resolve UI on a real conflicting PR). If unset, falls back
# to SYNERGIT_PR.
SYNERGIT_PR_CONFLICT=1
SYNERGIT_ISSUE=1
SYNERGIT_COMMIT=HEAD
SYNERGIT_BRANCH=main
SYNERGIT_FILE=README.md
# Compare-page route: <base>...<head>
SYNERGIT_COMPARE=main...feature

# ─── Optional Playwright knobs ──────────────────────────────────────────────
# Viewport size; the script always uses deviceScaleFactor=2 (retina).
# CAPTURE_W=1440
# CAPTURE_H=900
