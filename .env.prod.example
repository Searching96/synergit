# Database configuration
DB_USER=synergit_user
DB_PASSWORD=your_secure_database_password
DB_NAME=synergit

# Image configuration
# Use a registry namespace in production, e.g. ghcr.io/your_org/synergit
IMAGE_REGISTRY=synergit
IMAGE_TAG=latest

# Backend configuration
# Generate a secure random string for production
JWT_SECRET=your_jwt_secret_key_here

# Port configuration
APP_PORT=7080
HTTPS_PORT=7443

# Frontend URL
# Change this to your actual VPS IP address or domain name
FRONTEND_URL=https://your_vps_ip_address:7443
# Public Git Smart HTTP clone/push URL shown in the web UI.
GIT_BASE_URL=https://your_vps_ip_address:7443
