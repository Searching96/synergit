# Dev database configuration
DB_USER=synergit_dev_user
DB_PASSWORD=synergit_dev_password
DB_NAME=synergit_dev

# Dev image configuration
IMAGE_REGISTRY=synergit
IMAGE_TAG=dev
# FRONTEND_DEV_IMAGE=node:20-alpine

# Dev backend configuration
JWT_SECRET=dev_only_insecure_secret_change_me
FRONTEND_URL=http://localhost:25173
FRONTEND_URLS=http://127.0.0.1:25173,http://localhost:25173
GIT_BASE_URL=http://127.0.0.1:28080

# VPS dev tunnel ports
DEV_FRONTEND_PORT=25173
DEV_BACKEND_PORT=28080

# docker-compose.dev.yml derives dev URLs from these ports.
